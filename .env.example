# --- Provider API keys (set at least one) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# --- App settings ---
ACTIVE_MODEL=gemini
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:10000
PRODUCTION=false
